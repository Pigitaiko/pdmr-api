# Copy to .env (gitignored) and fill in. Never commit .env.
DATABASE_URL=postgresql+asyncpg://pdmr:pdmr@localhost:5432/pdmr
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
# Put a REAL reachable contact in your local .env per the source-politeness policy.
USER_AGENT=PDMR-API-bot/0.1 (+https://github.com/Pigitaiko/pdmr-api)
# set to any secret to enable GET /v1/admin/refresh?token=... (on-demand scrape). empty = disabled.
ADMIN_TOKEN=
